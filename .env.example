# Copy this file to .env and fill in your values
# cp .env.example .env

# ── API ────────────────────────────────────────────────────────────────────────
PROJECT_NAME="OpenStack VM Lifecycle API"
VERSION="1.0.0"

# Set to true to run without a real OpenStack (uses in-memory mock data)
MOCK_MODE=true

# ── OpenStack Credentials ──────────────────────────────────────────────────────
OS_AUTH_URL=http://your-keystone-host:5000/v3
OS_USERNAME=admin
OS_PASSWORD=your-password
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne
OS_IDENTITY_API_VERSION=3

# ── Nova / Compute ─────────────────────────────────────────────────────────────
OS_COMPUTE_API_VERSION=2.87
# OS_NOVA_URL=  # Leave blank to auto-discover from service catalog

# ── Connection Tuning ──────────────────────────────────────────────────────────
OS_CONNECT_TIMEOUT=10
OS_READ_TIMEOUT=30
OS_MAX_RETRIES=3

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
